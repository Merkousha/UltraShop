# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (PostgreSQL)
# Example:
# DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=
DB_CONN_MAX_AGE=60
USE_DJANGO_TENANTS=True
TENANT_PATH_PREFIX=s
# Optional: disable/enable SSL based on your provider requirements
# DB_SSLMODE=require

# Optional: django-tenants (URL path mode)
# Requires PostgreSQL and a tenant row per store slug.
USE_DJANGO_TENANTS=False
TENANT_PATH_PREFIX=s

# Optional
PLATFORM_DOMAIN=localhost:8000
PLATFORM_COMMISSION_RATE=0.05
PAYMENT_GATEWAY=mock
