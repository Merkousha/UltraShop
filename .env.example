# Copy to .env and set values. For production (e.g. HELPIO.IR) set these.

# Required in production
DJANGO_SECRET_KEY=your-long-random-secret-key
DJANGO_DEBUG=0

# Domain: platform root and store subdomains (e.g. helpio.ir, mystore.helpio.ir)
PLATFORM_ROOT_DOMAIN=helpio.ir

# Comma-separated. Leading dot = that domain + all subdomains.
ALLOWED_HOSTS=helpio.ir,.helpio.ir,www.helpio.ir

# CSRF: full URLs with scheme. Use https://*.helpio.ir for all store subdomains.
CSRF_TRUSTED_ORIGINS=https://helpio.ir,https://www.helpio.ir,https://*.helpio.ir

# Optional
# ALLOWED_HOSTS=...
# DEFAULT_FROM_EMAIL=noreply@helpio.ir
# PAYMENT_GATEWAY=zarinpal
# ZARINPAL_MERCHANT_ID=...
# ZARINPAL_SANDBOX=0
